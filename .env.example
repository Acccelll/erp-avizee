# Variáveis de ambiente — ERP AviZee

# Supabase (obrigatório)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-aqui

# SEED - APENAS PARA DESENVOLVIMENTO LOCAL
# Descomente APENAS quando quiser executar seed em ambiente local
# ALLOW_SEED=true

# Atalho de login rápido (apenas dev) — preenche o formulário automaticamente
# Defina em .env.local (não comitar credenciais reais)
# VITE_DEV_EMAIL=dev@seudominio.com
# VITE_DEV_PASSWORD=sua-senha-de-teste

# Sentry (opcional)
VITE_SENTRY_DSN=
